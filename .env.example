# -----------------------------------------------------------------------
# LifyGo — Environment Variables
# -----------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.
# -----------------------------------------------------------------------

# Server
PORT=8080
ENVIRONMENT=development

# PostgreSQL
POSTGRES_USER=lifygo
POSTGRES_PASSWORD=lifygo
POSTGRES_DB=lifygo
POSTGRES_PORT=5432
DATABASE_URL=postgres://lifygo:lifygo@localhost:5432/lifygo?sslmode=disable

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Clerk
CLERK_SECRET_KEY=

# Encryption
# AES-256 key, 64 hex characters (32 bytes). Generate with:
#   openssl rand -hex 32
ENCRYPTION_KEY=